on:
  schedule:
    - cron: '0 5,17 * * *'
  workflow_dispatch:
jobs:
  check-lote:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v3
    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.11'
    - name: Install dependencies
      run: pip install selenium requests webdriver-manager
    - name: Check TIE Lote
      id: check
      run: |
        python << 'PYTHON_EOF'
        from selenium import webdriver
        from selenium.webdriver.common.by import By
        from selenium.webdriver.support.ui import Select, WebDriverWait
        from selenium.webdriver.support import expected_conditions as EC
        from webdriver_manager.chrome import ChromeDriverManager
        from selenium.webdriver.chrome.service import Service
        import json
        from datetime import datetime
        import sys

        TARGET_LOTE = 114
        PROVINCE = "Málaga"
        OFFICE = "CNP Málaga Provincial"
        
        def check_lote():
            options = webdriver.ChromeOptions()
            options.add_argument('--headless')
            options.add_argument('--no-sandbox')
            options.add_argument('--disable-dev-shm-usage')
            
            driver = webdriver.Chrome(
                service=Service(ChromeDriverManager().install()),
                options=options
            )
            
            try:
                print("Загрузка form24.es...")
                driver.get("https://form24.es/en/lote/select")
                driver.implicitly_wait(5)
                
                province_select = WebDriverWait(driver, 15).until(
                    EC.presence_of_element_located((By.NAME, "province"))
                )
                Select(province_select).select_by_visible_text(PROVINCE)
                driver.implicitly_wait(4)
                
                office_select = driver.find_element(By.NAME, "office")
                Select(office_select).select_by_visible_text(OFFICE)
                driver.implicitly_wait(4)
                
                lote_text = None
                try:
                    lote_elem = driver.find_element(By.XPATH, "//*[contains(text(), '2026') and contains(text(), '/')]")
                    lote_text = lote_elem.text.strip()
                except:
                    pass
                
                if not lote_text:
                    import re
                    page_text = driver.page_source
                    matches = re.findall(r'2026/\d+', page_text)
                    if matches:
                        lote_text = matches[0]
                
                if lote_text:
                    lote_num = int(lote_text.split("/")[-1])
                    print(f"Найден лот: {lote_text}")
                    
                    result = {
                        'lote_text': lote_text,
                        'lote_num': lote_num,
                        'target': TARGET_LOTE,
                        'ready': lote_num >= TARGET_LOTE,
                        'remaining': max(0, TARGET_LOTE - lote_num)
                    }
                    
                    with open('lote_result.json', 'w') as f:
                        json.dump(result, f)
                    
                    return result['ready']
                else:
                    print("Не удалось найти номер лота")
                    return False
                
            except Exception as e:
                print(f"Ошибка: {e}")
                return False
            finally:
                driver.quit()
        
        success = check_lote()
        sys.exit(0 if success else 1)
        PYTHON_EOF
    
